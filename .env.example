# Backend API keys (set these in Cloud Run env vars for production)
GOOGLE_API_KEY=your_google_api_key_here
COURTLISTENER_API_TOKEN=your_courtlistener_token_here

# Model — defaults to Gemini 3 (see backend/model_config.py). Override here if
# your project exposes a different Gemini 3 model id, or to fall back to 2.5:
# LAWYERED_MODEL=gemini-2.5-flash

# --- Elastic (optional — semantic case-law RAG, memory, user-doc search) -----
# All optional: if unset, the backend runs CourtListener-only (graceful degrade).
#
# 1) Direct Elasticsearch access (seed script, index-on-read cache, memory/doc
#    writes, and the local stdio MCP fallback):
# ELASTICSEARCH_URL=https://your-project.es.us-central1.gcp.elastic.cloud:443
# ELASTIC_API_KEY=your_elasticsearch_api_key
# ELASTIC_INFERENCE_ID=.elser-2-elasticsearch   # override only if your endpoint differs
#
# 2) Hosted Elastic Agent Builder MCP server (the production / hackathon path):
# ELASTIC_MCP_URL=https://your-kibana.kb.us-central1.gcp.elastic.cloud/api/agent_builder/mcp
#    (ELASTIC_API_KEY above is reused as the `Authorization: ApiKey ...` header)
#
# 3) Force the LOCAL stdio Elastic MCP instead of the remote one (offline/demo):
# LAWYERED_ELASTIC_LOCAL=1

# Frontend (set in Cloud Run env vars for production)
BACKEND_URL=http://127.0.0.1:8080
