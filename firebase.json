{
  "hosting": {
    "public": "frontend/public",
    "rewrites": [
      {
        "source": "**",
        "run": {
          "serviceId": "lawyered-frontend",
          "region": "us-central1"
        }
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "database": "lawyered"
  }
}
